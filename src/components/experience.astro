---
const experiences = [
  {
    role: 'Senior Software Engineer',
    company: 'Tech Ventures Group',
    duration: 'Jun 2024 - Present',
    location: 'California, United States (Remote)',
    highlights: [
      'Architected an AI-powered email/newsletter builder with Next.js and React, featuring an LLM chat interface for automated content generation',
      'Developed and scaled AI infrastructure including data pipelines and monitoring tools to ensure 99.9% reliability of LLM-based services',
      'Implemented automated testing for complex data manipulation workflows using Python and Pandas',
    ]
  },
  {
    role: 'Lead Software Engineer',
    company: 'CribStore Innovations Pvt Ltd',
    duration: 'Nov 2023 - Aug 2024',
    location: 'Hyderabad, India (Hybrid)',
    highlights: [
      'Led the full-stack design of MERN-based microservices with RabbitMQ for async messaging and Redis for caching',
      'Orchestrated AWS cloud infrastructure (EC2, S3) for highly scalable real estate service applications',
    ]
  },
  {
    role: 'Software Engineer',
    company: 'Blackcoffer',
    duration: 'Jan 2023 - Nov 2023',
    location: 'New Delhi, India (Remote)',
    highlights: [
      'Built Toowe.io, a social media automation platform enabling concurrent publishing across Facebook, Instagram, and Twitter',
      'Containerized application services using Docker and Nginx for environment consistency across the development lifecycle',
    ]
  },
  {
    role: 'Associate Software Engineer (Intern)',
    company: 'Blackcoffer',
    duration: 'Jul 2022 - Jan 2023',
    location: 'New Delhi, India (Remote)',
    highlights: [
      'Built and maintained full-stack web applications using Node.js, React, and Docker',
    ]
  }
];
---
<section id="experience" class="py-12 border-t border-[#ffffff10] text-[var(--white)]">
  <div class="max-w-5xl mx-auto">
    <p class="text-lg text-[var(--sec)] mb-2 shiny-sec">Experience</p>
    <h2 class="text-4xl md:text-5xl font-medium mb-8">Work Experience</h2>
    <div class="space-y-8">
      {experiences.map(exp => (
        <article class="p-6 bg-[#1414149c] rounded-xl shadow-lg transition duration-300 ease-in-out transform hover:scale-[1.02] hover:bg-[#1a1a1a]">
          <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-2">
            <h3 class="text-2xl font-semibold">{exp.role}</h3>
            <span class="text-sm text-[var(--sec)]">{exp.duration}</span>
          </div>
          <p class="text-sm text-[var(--white-icon)] mb-3">{exp.company} &middot; {exp.location}</p>
          <ul class="space-y-2">
            {exp.highlights.map(h => (
              <li class="text-[var(--white-icon)] text-sm flex gap-2">
                <span class="text-[var(--sec)] mt-1 shrink-0">&bull;</span>
                <span>{h}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

---
import SectionHeading from "@/components/sectionHeading.astro";
import { experience, education } from "@/data/site";
---

<section id="experience" class="border-b-3 border-ink">
  <div class="max-w-content mx-auto px-5 md:px-8 py-16 md:py-24">
    <SectionHeading index="02" title="Experience" />

    <div class="border-3 border-ink shadow-brutal bg-paper">
      {
        experience.map((job, i) => (
          <article
            class:list={[
              "grid md:grid-cols-[15rem_1fr]",
              i > 0 && "border-t-3 border-ink",
            ]}
          >
            <div class="border-b-3 md:border-b-0 md:border-r-3 border-ink bg-sun p-5">
              <div class="font-mono text-[13px] font-bold">{job.period}</div>
              <div class="font-mono text-[12px] mt-1">{job.location}</div>
            </div>

            <div class="p-5 md:p-6">
              <h3 class="font-display text-lg md:text-xl uppercase">
                {job.role}
                <span class="font-mono font-normal normal-case text-muted text-base">
                  {" "}
                  @ {job.company}
                </span>
              </h3>
              <ul class="mt-4 space-y-2.5">
                {job.points.map((pt) => (
                  <li class="flex gap-3 text-[15px] md:text-base leading-relaxed">
                    <span class="mt-2 shrink-0 h-2.5 w-2.5 bg-accent border-2 border-ink" />
                    <span>{pt}</span>
                  </li>
                ))}
              </ul>
            </div>
          </article>
        ))
      }

      <div class="grid md:grid-cols-[15rem_1fr] border-t-3 border-ink">
        <div class="border-b-3 md:border-b-0 md:border-r-3 border-ink bg-ink text-paper p-5">
          <div class="font-mono text-[13px] font-bold uppercase">Education</div>
        </div>
        <div class="p-5 md:p-6 space-y-4">
          {
            education.map((e) => (
              <div>
                <div class="font-display text-base uppercase">{e.school}</div>
                <div class="text-[15px] text-muted">{e.detail}</div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

---
import SectionHeading from "@/components/sectionHeading.astro";
import { skills } from "@/data/site";
---

<section id="skills" class="border-b-3 border-ink">
  <div class="max-w-content mx-auto px-5 md:px-8 py-16 md:py-24">
    <SectionHeading index="03" title="Skills & Tools" />

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        skills.map((group, i) => (
          <div class="border-3 border-ink bg-paper shadow-brutal">
            <h3
              class:list={[
                "font-mono text-[13px] font-bold uppercase tracking-wide px-4 py-2.5 border-b-3 border-ink",
                i === 0 ? "bg-accent text-paper" : "bg-ink text-paper",
              ]}
            >
              {group.label}
            </h3>
            <ul class="flex flex-wrap gap-2 p-4">
              {group.items.map((item) => (
                <li class="font-mono text-[12px] font-medium border-2 border-ink px-2 py-1 hover:bg-sun">
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>

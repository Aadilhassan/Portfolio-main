---
import SectionHeading from "@/components/sectionHeading.astro";
import { skills } from "@/data/site";
---

<section id="skills" class="max-w-content mx-auto px-6 md:px-10 py-20 md:py-28">
  <SectionHeading index="03" title="Skills & Tools" />

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {
      skills.map((group) => (
        <div
          data-reveal
          class="border border-line rounded-xl bg-surface/30 p-6 md:p-7 hover:border-accent/30 transition-colors"
        >
          <h3 class="font-mono text-[12px] uppercase tracking-wider text-accent mb-4">
            {group.label}
          </h3>
          <ul class="flex flex-wrap gap-2">
            {group.items.map((item) => (
              <li class="text-[13px] text-txt/85 border border-line rounded-md px-2.5 py-1 hover:border-accent/50 hover:text-txt transition-colors">
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</section>

---
interface Props {
  index: string;
  title: string;
}
const { index, title } = Astro.props;
---

<div class="flex items-center gap-4 mb-12">
  <span
    class="font-mono font-bold text-sm bg-ink text-paper px-3 py-2 border-3 border-ink"
    >{index}</span
  >
  <h2 class="font-display text-3xl md:text-5xl uppercase leading-none">
    {title}
  </h2>
  <span class="hidden sm:block flex-1 border-t-3 border-ink"></span>
</div>

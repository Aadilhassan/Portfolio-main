---
interface Props {
  index: string;
  title: string;
}
const { index, title } = Astro.props;
---

<div data-reveal class="flex items-baseline gap-4 mb-10 md:mb-14">
  <span class="font-mono text-[13px] text-accent">{index}</span>
  <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">{title}</h2>
  <span class="flex-1 h-px bg-line self-center ml-2"></span>
</div>

---
import { profile } from "@/data/site";

const links = [
  { label: "WORK", href: "#work" },
  { label: "EXPERIENCE", href: "#experience" },
  { label: "SKILLS", href: "#skills" },
  { label: "CONTACT", href: "#contact" },
];
---

<header class="fixed top-0 inset-x-0 z-50 bg-paper border-b-3 border-ink">
  <nav
    class="max-w-content mx-auto px-5 md:px-8 h-[72px] flex items-center justify-between gap-4"
  >
    <a
      href="#top"
      class="font-mono font-bold text-base tracking-tight"
      aria-label="Back to top"
    >
      AADIL<span class="text-accent">.</span>HASSAN
    </a>

    <div class="flex items-center gap-2 md:gap-4">
      <ul class="hidden md:flex items-center">
        {
          links.map((l) => (
            <li>
              <a
                href={l.href}
                class="font-mono text-[13px] font-medium px-3 py-2 hover:bg-sun hover:outline hover:outline-3 hover:outline-ink"
              >
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
      <a
        href={profile.resume}
        target="_blank"
        rel="noopener"
        class="font-mono text-[13px] font-bold bg-accent text-paper border-3 border-ink px-4 py-2 shadow-brutal-sm hover:bg-ink"
      >
        RÉSUMÉ ↓
      </a>
    </div>
  </nav>
</header>

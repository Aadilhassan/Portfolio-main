---
interface Project {
  title: string;
  description: string;
  link: string;
  preview: string;
  status: string;
  tags: string[];
}

const featuredProjects: Project[] = [
  {
    title: "RealStateVideo",
    description: "Automated real estate video generation platform. 30-40 signups in 3 months, working on paid conversion.",
    link: "https://realstatevideo.com",
    preview: "https://realstatevideo.com",
    status: "Active",
    tags: ["Automation", "Video", "Real Estate", "SaaS"],
  },
  {
    title: "RankOps",
    description: "Autonomous SEO agent for Webflow CMS. AI-powered content optimization and ranking.",
    link: "https://rankops.com",
    preview: "https://rankops.com",
    status: "In Development",
    tags: ["AI", "SEO", "Agents", "SaaS"],
  },
];

const otherProjects = [
  {
    title: "MarketifyALL",
    description: "All-in-one AI marketing suite with website generation, automated deployment, and analytics",
    link: "https://marketifyall.com",
    tags: ["AI", "Marketing", "Next.js"],
  },
  {
    title: "Quenzy",
    description: "AI-powered examination proctoring platform with automated question generation",
    link: "https://quenzy.com",
    tags: ["AI", "EdTech", "Ollama"],
  },
  {
    title: "DealersDash",
    description: "Automotive business intelligence SaaS with financial forecasting and predictive insights",
    link: "https://app.dealerdash.ai",
    tags: ["Data Viz", "Forecasting"],
  },
  {
    title: "Finance Tracker",
    description: "Personal finance dashboard with MCP server integration",
    link: "https://finance.aadilhassan.in",
    tags: ["FinTech", "Personal Tool"],
  },
  {
    title: "Toowe",
    description: "Social media automation platform for concurrent content publishing",
    link: "https://app.toowe.io",
    tags: ["Automation", "Social Media"],
  },
];
---

<section
  id="projects"
  class="py-12 border-t border-[#ffffff10] text-[var(--white)]"
>
  <div class="max-w-5xl mx-auto">
    <p class="text-lg text-[var(--sec)] mb-2 shiny-sec">My work</p>
    <h2 class="text-4xl md:text-5xl font-medium mb-8">Projects by Aadil Hassan</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {
        featuredProjects.map((project) => (
          <a
            href={project.preview}
            target="_blank"
            rel="noopener noreferrer"
            class="group block p-6 bg-[#1414149c] rounded-2xl border border-[var(--white-icon-tr)] shadow-lg transition duration-300 ease-in-out transform hover:scale-[1.02] hover:border-[var(--sec)] hover:bg-[#1a1a1a]"
          >
            <div class="flex items-center justify-between mb-3">
              <h3 class="text-2xl font-semibold">{project.title}</h3>
              <span class="text-xs px-3 py-1 rounded-full bg-[var(--sec)] text-[var(--background)] font-medium">
                {project.status}
              </span>
            </div>
            <p class="text-[var(--white-icon)] text-sm mb-4 leading-relaxed">
              {project.description}
            </p>
            <div class="flex flex-wrap gap-2">
              {project.tags.map((tag) => (
                <span class="text-xs px-2 py-1 rounded-md bg-[var(--white-icon-tr)] text-[var(--white-icon)]">
                  {tag}
                </span>
              ))}
            </div>
          </a>
        ))
      }
    </div>

    <div class="mt-12">
      <h3 class="text-3xl md:text-4xl font-medium mb-8">More Projects</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {otherProjects.map((proj) => (
          <a
            href={proj.link}
            target="_blank"
            rel="noopener noreferrer"
            class="group block p-5 bg-[#1414149c] rounded-xl border border-[var(--white-icon-tr)] transition duration-300 ease-in-out transform hover:scale-[1.02] hover:border-[var(--sec)] hover:bg-[#1a1a1a]"
          >
            <h4 class="text-xl font-semibold mb-2">{proj.title}</h4>
            <p class="text-[var(--white-icon)] text-sm mb-3 leading-relaxed">{proj.description}</p>
            <div class="flex flex-wrap gap-2">
              {proj.tags.map((tag) => (
                <span class="text-xs px-2 py-1 rounded-md bg-[var(--white-icon-tr)] text-[var(--white-icon)]">
                  {tag}
                </span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>

    <a
      target="_blank"
      href="https://github.com/aadilhassan?tab=repositories"
      rel="noopener noreferrer me"
      aria-label="Aadil Hassan's GitHub repositories"
      class="w-full flex items-center justify-center gap-2 mt-9 text-[var(--white-icon)] hover:text-white transition duration-300 ease-in-out border border-[var(--white-icon-tr)] p-3 rounded-full bg-[#1414149c] hover:bg-[var(--white-icon-tr)] transform hover:scale-105"
    >
      <span class="md:text-lg text-md">More projects on</span>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="currentColor"
        class="size-6"
      >
        <path
          d="M12.001 2C6.47598 2 2.00098 6.475 2.00098 12C2.00098 16.425 4.86348 20.1625 8.83848 21.4875C9.33848 21.575 9.52598 21.275 9.52598 21.0125C9.52598 20.775 9.51348 19.9875 9.51348 19.15C7.00098 19.6125 6.35098 18.5375 6.15098 17.975C6.03848 17.6875 5.55098 16.8 5.12598 16.5625C4.77598 16.375 4.27598 15.9125 5.11348 15.9C5.90098 15.8875 6.46348 16.625 6.65098 16.925C7.55098 18.4375 8.98848 18.0125 9.56348 17.75C9.65098 17.1 9.91348 16.6625 10.201 16.4125C7.97598 16.1625 5.65098 15.3 5.65098 11.475C5.65098 10.3875 6.03848 9.4875 6.67598 8.7875C6.57598 8.5375 6.22598 7.5125 6.77598 6.1375C6.77598 6.1375 7.61348 5.875 9.52598 7.1625C10.326 6.9375 11.176 6.825 12.026 6.825C12.876 6.825 13.726 6.9375 14.526 7.1625C16.4385 5.8625 17.276 6.1375 17.276 6.1375C17.826 7.5125 17.476 8.5375 17.376 8.7875C18.0135 9.4875 18.401 10.375 18.401 11.475C18.401 15.3125 16.0635 16.1625 13.8385 16.4125C14.201 16.725 14.5135 17.325 14.5135 18.2625C14.5135 19.6 14.501 20.675 14.501 21.0125C14.501 21.275 14.6885 21.5875 15.1885 21.4875C19.259 20.1133 21.9999 16.2963 22.001 12C22.001 6.475 17.526 2 12.001 2Z"
        ></path>
      </svg>
    </a>
  </div>
</section>

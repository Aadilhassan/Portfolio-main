---
import SectionHeading from "@/components/sectionHeading.astro";
import { projects, alsoBuilt } from "@/data/site";
---

<section id="work" class="max-w-content mx-auto px-6 md:px-10 py-20 md:py-28">
  <SectionHeading index="01" title="Selected Work" />

  <div class="flex flex-col">
    {
      projects.map((p, i) => (
        <article
          data-reveal
          class="group grid md:grid-cols-[3.5rem_1fr] gap-x-6 gap-y-4 border-t border-line py-8 md:py-10 transition-colors hover:bg-surface/40 -mx-4 px-4 rounded-lg"
        >
          <div class="font-mono text-[13px] text-faint pt-1.5">
            {String(i + 1).padStart(2, "0")}
          </div>

          <div>
            <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
              <h3 class="text-2xl md:text-3xl font-semibold tracking-tight text-txt group-hover:text-accent transition-colors">
                {p.name}
              </h3>
              <span class="font-mono text-[13px] text-muted">{p.kind}</span>
            </div>

            <p class="mt-4 max-w-3xl text-[15px] md:text-base text-muted leading-relaxed text-pretty">
              {p.description}
            </p>

            <div class="mt-5 flex flex-wrap items-center gap-2">
              {p.stack.map((s) => (
                <span class="font-mono text-[11px] text-faint border border-line rounded-md px-2 py-1">
                  {s}
                </span>
              ))}
            </div>

            {p.links && (
              <div class="mt-5 flex flex-wrap gap-5">
                {p.links.map((l) => (
                  <a
                    href={l.href}
                    target="_blank"
                    rel="noopener"
                    class="link-underline inline-flex items-center gap-1.5 font-mono text-[13px] text-txt hover:text-accent transition-colors"
                  >
                    {l.label}
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M7 17 17 7M9 7h8v8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </a>
                ))}
              </div>
            )}
          </div>
        </article>
      ))
    }
  </div>

  <p
    data-reveal
    class="border-t border-line pt-8 mt-2 text-[15px] text-muted leading-relaxed"
  >
    <span class="font-mono text-[13px] text-faint">Also built &nbsp;/&nbsp;</span>
    {alsoBuilt}
  </p>
</section>

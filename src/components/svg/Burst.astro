---
// 8-point asterisk burst, hand-drawn feel.
interface Props {
  class?: string;
  fill?: string;
}
const { class: className = "w-8 h-8", fill = "#141414" } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 48 48"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <path
    d="M24 2 L27 17 L38 6 L31 20 L46 19 L32 25 L44 34 L29 30 L32 46 L24 32 L16 46 L19 30 L4 34 L16 25 L2 19 L17 20 L10 6 L21 17 Z"
    fill={fill}></path>
</svg>

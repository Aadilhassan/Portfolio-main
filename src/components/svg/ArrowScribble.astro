---
// Hand-drawn curved arrow pointing down-right.
interface Props {
  class?: string;
  stroke?: string;
}
const { class: className = "w-16 h-16", stroke = "#141414" } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 64 64"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <path
    d="M8 6 C 34 10 52 26 54 50"
    stroke={stroke}
    stroke-width="4"
    stroke-linecap="round"></path>
  <path
    d="M42 44 L54 52 L58 38"
    stroke={stroke}
    stroke-width="4"
    stroke-linecap="round"
    stroke-linejoin="round"></path>
</svg>

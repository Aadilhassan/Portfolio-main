---
import { profile } from "@/data/site";
---

<footer class="border-t border-line">
  <div
    class="max-w-content mx-auto px-6 md:px-10 py-10 flex flex-col sm:flex-row items-center justify-between gap-4"
  >
    <p class="font-mono text-[12px] text-faint">
      © 2026 {profile.name} · Ranchi, India
    </p>
    <div class="flex items-center gap-6 font-mono text-[12px]">
      <span class="text-faint">Built with Astro &amp; Tailwind</span>
      <a href="#top" class="text-muted hover:text-accent transition-colors"
        >Back to top ↑</a
      >
    </div>
  </div>
</footer>

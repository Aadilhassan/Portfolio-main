---
import SectionHeading from "@/components/sectionHeading.astro";
import Burst from "@/components/svg/Burst.astro";
import { about } from "@/data/site";
---

<section id="about" class="border-b-3 border-ink">
  <div class="max-w-content mx-auto px-5 md:px-8 py-16 md:py-24">
    <SectionHeading index="00" title="About" />

    <div class="grid md:grid-cols-[1fr_1.5fr] gap-8 md:gap-14 items-start">
      <div class="border-3 border-ink bg-sun p-6 shadow-brutal">
        <Burst class="w-8 h-8 mb-4" fill="#141414" />
        <p class="font-mono text-sm font-bold uppercase leading-relaxed">
          Full-stack engineer.<br />
          AI-native products.<br />
          Owns everything from architecture to production.
        </p>
      </div>

      <div class="space-y-6">
        {
          about.map((para) => (
            <p class="text-lg md:text-xl leading-relaxed">{para}</p>
          ))
        }
      </div>
    </div>
  </div>
</section>

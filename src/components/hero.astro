---
import { profile, stats } from "@/data/site";
---

<section id="top" class="max-w-content mx-auto px-6 md:px-10">
  <div class="min-h-[88vh] flex flex-col justify-center pt-28 pb-16">
    <p
      data-reveal
      class="font-mono text-[13px] text-accent tracking-wide flex items-center gap-2.5"
    >
      <span class="relative flex h-2 w-2">
        <span
          class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-60"
        ></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-accent"></span>
      </span>
      {profile.title} · Available for work
    </p>

    <h1
      data-reveal
      style="transition-delay:80ms"
      class="mt-6 text-6xl sm:text-7xl md:text-8xl font-semibold tracking-tight leading-[0.95]"
    >
      {profile.name}
    </h1>

    <p
      data-reveal
      style="transition-delay:160ms"
      class="mt-8 max-w-2xl text-lg md:text-2xl text-muted leading-relaxed text-balance"
    >
      {profile.tagline}
    </p>

    <div
      data-reveal
      style="transition-delay:240ms"
      class="mt-10 flex flex-wrap items-center gap-3"
    >
      <a
        href={`mailto:${profile.email}`}
        class="group inline-flex items-center gap-2 rounded-lg bg-accent px-5 py-2.5 text-ink font-medium text-sm hover:bg-accent/90 transition-colors"
      >
        Get in touch
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" class="transition-transform group-hover:translate-x-0.5"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>

      <a
        href={profile.github}
        target="_blank"
        rel="noopener me"
        aria-label="GitHub"
        class="inline-flex h-11 w-11 items-center justify-center rounded-lg border border-line text-muted hover:text-txt hover:border-accent transition-colors"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.475 2 2 6.475 2 12c0 4.425 2.863 8.163 6.838 9.488.5.087.687-.213.687-.475 0-.237-.012-1.025-.012-1.862-2.513.462-3.163-.613-3.363-1.175-.113-.288-.6-1.175-1.025-1.413-.35-.187-.85-.65-.013-.662.788-.012 1.35.725 1.538 1.025.9 1.512 2.338 1.087 2.912.825.088-.65.35-1.087.638-1.337-2.225-.25-4.55-1.113-4.55-4.938 0-1.088.387-1.987 1.025-2.688-.1-.25-.45-1.275.1-2.65 0 0 .837-.262 2.75 1.026a9.28 9.28 0 0 1 2.5-.338c.85 0 1.7.112 2.5.337 1.912-1.3 2.75-1.024 2.75-1.024.55 1.375.2 2.4.1 2.65.637.7 1.025 1.587 1.025 2.687 0 3.838-2.337 4.688-4.562 4.938.362.312.675.912.675 1.85 0 1.337-.013 2.412-.013 2.75 0 .262.188.574.688.474A10.016 10.016 0 0 0 22 12c0-5.525-4.475-10-10-10Z"/></svg>
      </a>

      <a
        href={profile.linkedin}
        target="_blank"
        rel="noopener me"
        aria-label="LinkedIn"
        class="inline-flex h-11 w-11 items-center justify-center rounded-lg border border-line text-muted hover:text-txt hover:border-accent transition-colors"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.336 18.339h-2.665v-4.177c0-.996-.02-2.278-1.388-2.278-1.39 0-1.601 1.084-1.601 2.205v4.25h-2.666V9.75h2.56v1.17h.035c.358-.674 1.228-1.387 2.528-1.387 2.7 0 3.2 1.778 3.2 4.091v4.715ZM7.004 8.575a1.548 1.548 0 1 1 0-3.096 1.548 1.548 0 0 1 0 3.096Zm1.336 9.764H5.667V9.75H8.34v8.589ZM19.67 3H4.329C3.595 3 3 3.581 3 4.297v15.406C3 20.42 3.595 21 4.329 21H19.67c.734 0 1.33-.58 1.33-1.297V4.297C21 3.581 20.404 3 19.67 3Z"/></svg>
      </a>

      <a
        href={`mailto:${profile.email}`}
        aria-label="Email"
        class="inline-flex h-11 w-11 items-center justify-center rounded-lg border border-line text-muted hover:text-txt hover:border-accent transition-colors"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="m18.73 5.41-1.28 1L12 10.46 6.55 6.37l-1.28-1A2 2 0 0 0 2 7.05v11.59A1.36 1.36 0 0 0 3.36 20h3.19v-7.72L12 16.37l5.45-4.09V20h3.19A1.36 1.36 0 0 0 22 18.64V7.05a2 2 0 0 0-3.27-1.64Z"/></svg>
      </a>
    </div>

    <p
      data-reveal
      style="transition-delay:300ms"
      class="mt-8 font-mono text-[13px] text-faint"
    >
      {profile.location} · {profile.availability}
    </p>
  </div>

  <!-- Stat strip -->
  <div
    data-reveal
    class="grid grid-cols-2 md:grid-cols-4 gap-px rounded-xl overflow-hidden border border-line bg-line"
  >
    {
      stats.map((s) => (
        <div class="bg-ink px-5 py-6">
          <div class="text-2xl md:text-3xl font-semibold tracking-tight text-txt">
            {s.value}
          </div>
          <div class="mt-1.5 font-mono text-[11px] uppercase tracking-wider text-muted leading-snug">
            {s.label}
          </div>
        </div>
      ))
    }
  </div>
</section>
